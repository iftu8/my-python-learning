import re

def check_password_strength(password):
    # পাসওয়ার্ডের শক্তি পরীক্ষা করার লজিক
    strength = 0
    remarks = ""
    
    if len(password) >= 8: strength += 1
    if re.search("[a-z]", password) and re.search("[A-Z]", password): strength += 1
    if re.search("[0-9]", password): strength += 1
    if re.search("[_@$!%*#?&]", password): strength += 1
    
    if strength == 4:
        remarks = "অসাধারণ! অত্যন্ত শক্তিশালী পাসওয়ার্ড। 💪"
    elif strength == 3:
        remarks = "মাঝারি শক্তিশালী। আর একটু ভালো করা যায়। ⚠️"
    else:
        remarks = "খুবই দুর্বল পাসওয়ার্ড! হ্যাক হওয়ার ঝুঁকি আছে। ❌"
        
    return remarks

user_pass = input("আপনার পাসওয়ার্ডটি টেস্ট করুন: ")
print(check_password_strength(user_pass))
